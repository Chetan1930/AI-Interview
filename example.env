# Copy this to .env and fill in your values
# MongoDB (required for auth and session persistence)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.z5tr4o7.mongodb.net/AI-Interview

# JWT Secret for auth tokens (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Gemini API (existing - for AI features)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Supabase (optional - not currently used)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
